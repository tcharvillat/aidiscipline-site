---
import data from '../../data/faq.json';

const faq = data.faq;
---

<section id="faq" class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-4xl px-6 md:px-8 lg:px-12">
    <div class="mx-auto max-w-3xl space-y-3 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-500">
        FAQ
      </p>
      <h2 class="text-display-lg font-bold leading-tight text-ink">
        Vos questions sur nos formations IA
      </h2>
    </div>

    <div class="mt-12 space-y-3">
      {faq.map((item) => (
        <details class="faq-item group rounded-2xl border border-gray-100 bg-white shadow-card transition-shadow open:shadow-card-hover">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-6 text-left font-semibold text-ink">
            <span class="flex-1">{item.question}</span>
            <svg
              class="h-5 w-5 flex-shrink-0 text-brand-500 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div class="border-t border-gray-100 px-6 py-5 text-base leading-relaxed text-ink-muted">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
</style>
