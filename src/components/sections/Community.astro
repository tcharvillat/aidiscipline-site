---
import Button from '../ui/Button.astro';

const TYPEFORM_URL = 'https://discovery-discipline.typeform.com/aidiscipline';
---

<section id="community" class="bg-white py-8 md:py-12">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <div class="relative isolate overflow-hidden rounded-2xl shadow-card">
      <img
        src="/images/wix/community-street.png"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover"
        width="1920"
        height="700"
        loading="lazy"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-black/55 via-black/25 to-transparent" aria-hidden="true"></div>

      <div class="relative px-6 py-12 md:px-12 md:py-16 lg:px-16 lg:py-20">
        <div class="max-w-2xl">
          <p class="text-lg leading-relaxed text-white md:text-xl">
            AI Discipline, c'est aussi un espace Slack gratuit, ouvert à tous,
            pour progresser ensemble dans notre pratique de l'IA au quotidien.
          </p>

          <div class="mt-8">
            <Button
              href={TYPEFORM_URL}
              variant="primary"
              size="lg"
              external
              withArrow
            >
              Formulaire d'inscription
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
