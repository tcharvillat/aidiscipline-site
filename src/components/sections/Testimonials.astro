---
import TestimonialCard from '../ui/TestimonialCard.astro';
import data from '../../data/testimonials.json';

const testimonials = data.testimonials;
---

<section id="testimonials" class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <div class="mx-auto max-w-3xl space-y-3 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-500">
        Ils parlent de nos formations
      </p>
      <h2 class="text-display-lg font-bold leading-tight text-ink">
        Des PM, Designers et leaders qui ont franchi le cap
      </h2>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <TestimonialCard
          quote={t.quote}
          author={t.author}
          role={t.role}
          company={t.company}
          photo={t.photo}
          companyLogo={t.companyLogo}
        />
      ))}
    </div>
  </div>
</section>
