---
import TestimonialCard from '../ui/TestimonialCard.astro';
import data from '../../data/testimonials.json';

const testimonials = data.testimonials.slice(0, 6);
---

<section id="testimonials" class="bg-brand-50/60 py-10 md:py-14">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <div class="text-center">
      <h2 class="text-4xl font-light leading-tight text-ink md:text-5xl">
        Ils parlent de nos formations
      </h2>
      <div class="mx-auto mt-6 h-1 w-24 rounded-pill bg-brand-500"></div>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {testimonials.map((t) => (
        <TestimonialCard
          quote={t.quote}
          author={t.author}
          role={t.role}
          company={t.company}
          photo={t.photo}
          companyLogo={t.companyLogo}
        />
      ))}
    </div>
  </div>
</section>
