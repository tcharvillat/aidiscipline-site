---
import LogoCarousel from '../ui/LogoCarousel.astro';

// Les logos clients ont été téléchargés depuis Wix sous forme générique
// (logo1.png … logo19.png). Le mapping nom→numéro est à finaliser ;
// pour l'instant on les répartit sur deux bandeaux qui défilent.
const allLogos = Array.from({ length: 19 }, (_, i) => ({
  src: `/images/logos/logo${i + 1}.png`,
  alt: `Logo client ${i + 1}`,
}));

const firstRow = allLogos.slice(0, 9);
const secondRow = allLogos.slice(9);
---

<section id="client-logos" class="bg-white py-3 md:py-4">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <h2 class="mx-auto max-w-4xl text-center text-2xl font-bold leading-tight text-ink md:text-3xl lg:text-4xl">
      Parmi les 1.500+ PM, PO, Designers… de la communauté
    </h2>
  </div>

  <div class="mt-2">
    <LogoCarousel logos={firstRow} speed={45} />
    <LogoCarousel logos={secondRow} speed={55} />
  </div>
</section>
