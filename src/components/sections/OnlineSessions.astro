---
import Button from '../ui/Button.astro';
---

<section id="online-sessions" class="bg-ink pt-10 pb-6 text-white md:pt-14">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="space-y-6">
        <h2 class="text-4xl font-light leading-tight text-white md:text-5xl">
          Les sessions online
        </h2>
        <p class="text-base leading-relaxed text-white/85">
          Rejoignez des cohortes de formation en ligne. Sessions live +
          exercices pratiques corrigés + accès à notre communauté pratique.
          Flexible, actionnable, avec templates et méthodes prêts à l'emploi.
        </p>
        <div class="pt-2">
          <Button href="/formation-ia" variant="primary" size="lg" withArrow>
            Accéder au catalogue
          </Button>
        </div>
      </div>

      <div class="order-first lg:order-last">
        <img
          src="/images/brand/cohort.png"
          alt="Mosaïque d'une session AI Discipline en cohorte"
          class="w-full rounded-2xl shadow-card"
          width="1200"
          height="800"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
