---
import Button from '../ui/Button.astro';
---

<section id="online-sessions" class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-500">
          Les sessions online
        </p>
        <h2 class="text-display-lg font-bold leading-tight text-ink">
          Apprenez l'IA en cohorte, à votre rythme
        </h2>
        <p class="text-lg leading-relaxed text-ink-muted">
          Une heure live chaque semaine, des exercices individualisés, et des
          formateurs en activité qui partagent leurs cas d'usage. Suivez les
          formations qui font progresser votre équipe sans casser votre agenda.
        </p>
        <div class="pt-2">
          <Button href="/formation-ia" variant="primary" size="lg" withArrow>
            Accéder au catalogue
          </Button>
        </div>
      </div>

      <div class="relative order-first lg:order-last">
        <img
          src="/images/brand/cohort.png"
          alt="Capture d'une session AI Discipline en cohorte"
          class="w-full rounded-2xl shadow-card"
          width="719"
          height="648"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
