---
import Button from '../ui/Button.astro';

const CALENDLY_URL = 'https://calendly.com/remi-guyot/30min';
---

<section id="custom-days" class="bg-ink pt-6 pb-10 text-white md:pb-14">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <img
          src="/images/wix/customdays-training.jpg"
          alt="Une journée sur mesure AI Discipline"
          class="w-full rounded-2xl shadow-card"
          width="1200"
          height="900"
          loading="lazy"
        />
      </div>

      <div class="space-y-6">
        <h2 class="text-4xl font-light leading-tight text-white md:text-5xl">
          Les journées sur mesure
        </h2>
        <p class="text-base leading-relaxed text-white/85 md:text-lg">
          Une journée dédiée à vos équipes, et structurée autour de vos
          besoins spécifiques. Le formateur vous guide pas à pas, en
          travaillant sur vos données réelles et vos cas d'usage concrets,
          pour transformer la théorie en action dès la première session.
        </p>
        <div class="pt-2">
          <Button
            href={CALENDLY_URL}
            variant="primary"
            size="lg"
            external
            withArrow
          >
            Prendre rendez-vous
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
