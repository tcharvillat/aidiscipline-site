---
import Button from '../ui/Button.astro';

const CALENDLY_URL = 'https://calendly.com/remi-guyot/30min';
---

<section id="custom-days" class="bg-brand-50/40 py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-6 md:px-8 lg:px-12">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="relative">
        <img
          src="/images/brand/genie.png"
          alt="Atelier sur mesure AI Discipline"
          class="w-full rounded-2xl shadow-card"
          width="1200"
          height="800"
          loading="lazy"
        />
      </div>

      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-500">
          Les journées sur mesure
        </p>
        <h2 class="text-display-lg font-bold leading-tight text-ink">
          Embarquez toute votre équipe dans une journée IA
        </h2>
        <p class="text-lg leading-relaxed text-ink-muted">
          Un format intense, conçu pour vos enjeux : audit de vos workflows,
          ateliers pratiques sur vos outils, et alignement de toute l'équipe
          autour d'une roadmap IA. Sur site ou en distanciel, en français ou
          en anglais.
        </p>
        <div class="pt-2">
          <Button
            href={CALENDLY_URL}
            variant="primary"
            size="lg"
            external
            withArrow
          >
            Prendre rendez-vous
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
