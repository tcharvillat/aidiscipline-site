---
import QualiopiBadge from '../ui/QualiopiBadge.astro';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/formation-ia', label: 'Formations IA' },
  { href: '/terms-and-conditions', label: 'Mentions légales' },
];

const LINKEDIN_URL = 'https://www.linkedin.com/company/ai-discipline/';
const TYPEFORM_URL = 'https://discovery-discipline.typeform.com/aidiscipline';
const year = new Date().getFullYear();
---

<footer class="bg-ink text-white">
  <div class="mx-auto max-w-7xl px-6 py-10 md:px-8 md:py-12 lg:px-12">
    <div class="grid gap-10 lg:grid-cols-[1fr_auto] lg:items-start lg:gap-16">
      <div class="space-y-6">
        <a
          href="/"
          class="inline-flex items-center"
          aria-label="AI Discipline — accueil"
        >
          <img
            src="/images/brand/logo.png"
            alt="AI Discipline"
            class="h-12 w-auto"
            width="1257"
            height="1157"
          />
        </a>

        <p class="text-sm text-white/80">
          Formation IA et communauté Slack
        </p>

        <nav aria-label="Pied de page" class="-mt-3">
          <ul class="space-y-1">
            {navLinks.map((link, i) => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'text-sm transition-colors hover:text-brand-400',
                    i === 0 ? 'text-brand-500' : 'text-white/85',
                  ]}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="flex gap-3 pt-6">
          <a
            href={LINKEDIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-brand-500"
            aria-label="LinkedIn AI Discipline"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.024-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href={TYPEFORM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-brand-500"
            aria-label="Rejoindre la communauté Slack"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z" />
            </svg>
          </a>
        </div>

      </div>

      <div class="flex lg:justify-end">
        <QualiopiBadge compact={true} class="border border-white/15" />
      </div>
    </div>

    <p class="mt-10 border-t border-white/10 pt-6 text-xs leading-relaxed text-white/60">
      © {year} AI Discipline — Discovery Discipline SAS — SIRET 912 638 533 00014 — Déclaration d'activité n°11756928875 auprès du préfet de la région Île-de-France.
    </p>
  </div>
</footer>
