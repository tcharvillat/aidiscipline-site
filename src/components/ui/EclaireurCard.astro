---
export interface Props {
  name: string;
  role: string;
  bio: string;
  photo?: string;
}

const { name, role, bio, photo } = Astro.props;

const initials = name
  .split(' ')
  .map((part) => part[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<article class="group flex w-64 flex-shrink-0 snap-start flex-col">
  <div class="relative aspect-[4/5] w-full overflow-hidden rounded-t-md">
    {photo ? (
      <img
        src={photo}
        alt={`Portrait de ${name}`}
        class="absolute inset-0 h-full w-full object-cover transition-opacity duration-300 ease-out group-hover:opacity-0"
        loading="lazy"
        width="320"
        height="400"
      />
    ) : (
      <div
        class="absolute inset-0 flex items-center justify-center bg-brand-100 text-3xl font-semibold text-brand-700 transition-opacity duration-300 ease-out group-hover:opacity-0"
        aria-hidden="true"
      >
        {initials}
      </div>
    )}

    <div
      class="absolute inset-0 flex items-center bg-ink p-5 text-sm leading-relaxed text-white opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-100"
    >
      <p>{bio}</p>
    </div>

    <div class="absolute inset-x-0 bottom-0 z-10 h-2 bg-brand-500" aria-hidden="true"></div>
  </div>

  <h3 class="mt-4 text-base font-bold text-ink">{name}</h3>
  <p class="mt-1 inline-flex items-center gap-1 text-xs font-semibold uppercase tracking-wider text-ink-muted">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-500" aria-hidden="true">
      <line x1="7" y1="17" x2="17" y2="7" />
      <polyline points="7 7 17 7 17 17" />
    </svg>
    {role}
  </p>
</article>
