---
export interface Logo {
  src?: string;
  alt: string;
  /** Classe Tailwind d'échelle pour ajuster un logo individuellement (ex. "scale-125"). */
  scaleClass?: string;
}

export interface Props {
  logos: Logo[];
  /** Durée d'un cycle complet en secondes. Plus la valeur est grande, plus le défilement est lent. */
  speed?: number;
  /** Mettre l'animation en pause au survol. */
  pauseOnHover?: boolean;
}

const { logos, speed = 40, pauseOnHover = true } = Astro.props;

// Chaque logo s'inscrit dans une "boîte" de taille uniforme : on harmonise
// ainsi les largeurs visuelles entre logos carrés et wordmarks allongés.
const slotSize = 'h-12 w-36 md:h-16 md:w-48';

// On rend la liste deux fois : l'animation translate de 0 à -50%, ce qui
// produit une boucle infinie sans saut visible.
const doubled = [...logos, ...logos];
---

<div
  class="logo-carousel relative w-full overflow-hidden"
  data-pause-on-hover={pauseOnHover ? 'true' : 'false'}
  style={`--scroll-duration: ${speed}s;`}
>
  <div class="logo-track flex items-center gap-8 py-0 md:gap-12">
    {doubled.map((logo, i) => {
      const isClone = i >= logos.length;
      return (
        <div
          class={`flex flex-shrink-0 items-center justify-center ${slotSize}`}
          aria-hidden={isClone ? 'true' : undefined}
        >
          {logo.src ? (
            <img
              src={logo.src}
              alt={isClone ? '' : logo.alt}
              class={`max-h-full max-w-full object-contain opacity-60 grayscale transition duration-300 hover:opacity-100 hover:grayscale-0 ${logo.scaleClass ?? ''}`}
              loading="lazy"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center rounded-md bg-gray-100 px-3 text-xs font-medium text-ink-muted">
              {logo.alt}
            </div>
          )}
        </div>
      );
    })}
  </div>
</div>

<style>
  .logo-carousel {
    /* Fade sur les bords pour une transition douce */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 8%,
      black 92%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 8%,
      black 92%,
      transparent
    );
  }

  .logo-track {
    width: max-content;
    animation: logo-scroll-x var(--scroll-duration, 40s) linear infinite;
  }

  .logo-carousel[data-pause-on-hover='true']:hover .logo-track {
    animation-play-state: paused;
  }

  @keyframes logo-scroll-x {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-track {
      animation: none;
    }
  }
</style>
