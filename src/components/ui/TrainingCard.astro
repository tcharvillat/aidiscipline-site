---
import Button from './Button.astro';

export interface Props {
  title: string;
  description: string;
  format: string;
  price: string;
  priceNote?: string | null;
  rating?: number | null;
  url: string;
  banner?: string;
  /** Conservé pour compat API mais plus rendu. */
  trainer?: string;
}

const {
  title,
  description,
  format,
  price,
  priceNote,
  rating,
  url,
  banner,
} = Astro.props;

// "4 x 1 heure + Exercices asynchrones" → "4 x 1 heure"
const formatShort = format.split(/\s*\+\s*/)[0].trim();
const hasRating = typeof rating === 'number' && !Number.isNaN(rating);
---

<article class="group flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-card transition-all duration-200 hover:-translate-y-1 hover:shadow-card-hover">
  <!-- Bandeau noir : prix + mention, centrés verticalement -->
  <div class="flex min-h-14 items-center justify-between gap-3 bg-ink px-4 py-3">
    <span class="inline-flex items-center rounded-pill bg-white px-3 py-1 text-xs font-bold text-ink">
      {price}
    </span>
    {priceNote && (
      <span class="inline-flex items-center rounded-pill bg-brand-500 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-white">
        {priceNote}
      </span>
    )}
  </div>

  <!-- Image cliquable, pleine largeur, non tronquée -->
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="block w-full bg-ink"
    aria-label={`Voir la formation : ${title}`}
  >
    {banner ? (
      <img
        src={banner}
        alt={`Bannière de la formation : ${title}`}
        class="block h-auto w-full transition-transform duration-300 group-hover:scale-[1.02]"
        loading="lazy"
      />
    ) : (
      <div
        class="flex aspect-[1200/630] w-full items-center justify-center bg-gradient-to-br from-brand-100 via-brand-200 to-brand-300"
        aria-hidden="true"
      >
        <span class="text-sm font-medium text-brand-700/60">Bannière</span>
      </div>
    )}
  </a>

  <!-- Contenu -->
  <div class="flex flex-1 flex-col gap-4 p-6">
    <div class="flex items-center justify-between gap-3 text-sm">
      {hasRating ? (
        <span class="inline-flex items-center gap-1 font-semibold text-ink">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="#FACC15"
            aria-hidden="true"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21.02 7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
          <span aria-label={`Note : ${rating} sur 5`}>{rating!.toFixed(1)}</span>
        </span>
      ) : (
        <span class="inline-flex items-center rounded-pill bg-brand-500 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white">
          New
        </span>
      )}

      <span class="flex items-center gap-1 text-xs">
        <span class="font-semibold uppercase tracking-wider text-ink-light">
          Format
        </span>
        <span aria-hidden="true" class="text-ink-light">·</span>
        <span class="font-semibold text-ink">{formatShort}</span>
      </span>
    </div>

    <h3 class="text-lg font-semibold leading-snug text-ink line-clamp-3">
      {title}
    </h3>

    <p class="flex-1 text-sm leading-relaxed text-ink-muted line-clamp-4">
      {description}
    </p>

    <Button
      href={url}
      variant="secondary"
      size="md"
      external
      withArrow
      class="w-full"
    >
      Voir la formation
    </Button>
  </div>
</article>
