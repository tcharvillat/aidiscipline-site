---
import Button from './Button.astro';

export interface Props {
  title: string;
  description: string;
  format: string;
  price: string;
  priceNote?: string | null;
  rating?: number;
  url: string;
  banner?: string;
  trainer?: string;
}

const {
  title,
  description,
  format,
  price,
  priceNote,
  rating = 4.7,
  url,
  banner,
  trainer,
} = Astro.props;
---

<article class="group flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-card transition-all duration-200 hover:-translate-y-1 hover:shadow-card-hover">
  <div class="relative aspect-[16/9] w-full overflow-hidden">
    {banner ? (
      <img
        src={banner}
        alt={`Bannière de la formation ${title}`}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div
        class="flex h-full w-full items-center justify-center bg-gradient-to-br from-brand-100 via-brand-200 to-brand-300"
        aria-hidden="true"
      >
        <span class="text-sm font-medium text-brand-700/60">Bannière</span>
      </div>
    )}

    <div class="absolute left-4 top-4 inline-flex items-center rounded-pill bg-white px-3 py-1 text-xs font-bold text-ink shadow-card">
      {price}
    </div>

    {priceNote && (
      <div class="absolute right-4 top-4 inline-flex items-center rounded-pill bg-brand-500 px-3 py-1 text-[10px] font-semibold uppercase tracking-wider text-white shadow-card">
        {priceNote}
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col gap-4 p-6">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-ink-muted">
      <span class="inline-flex items-center gap-1 font-semibold text-ink">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="#FACC15"
          aria-hidden="true"
        >
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21.02 7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
        <span aria-label={`Note : ${rating} sur 5`}>{rating.toFixed(1)}</span>
      </span>
      <span aria-hidden="true" class="text-ink-light">·</span>
      <span>{format}</span>
    </div>

    <h3 class="text-lg font-semibold leading-snug text-ink line-clamp-3">
      {title}
    </h3>

    <p class="flex-1 text-sm leading-relaxed text-ink-muted line-clamp-4">
      {description}
    </p>

    {trainer && (
      <p class="text-xs uppercase tracking-wider text-ink-light">
        Formateur · <span class="font-semibold text-ink">{trainer}</span>
      </p>
    )}

    <Button
      href={url}
      variant="secondary"
      size="md"
      external
      withArrow
      class="w-full"
    >
      Voir la formation
    </Button>
  </div>
</article>
