---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI Discipline — Formations IA pour équipes Produit & Design"
  description="Organisme de formation IA pour les équipes Produit et Design. Formations en ligne, formats sur mesure, communauté Slack."
>
  <main class="mx-auto max-w-6xl px-6 py-24 md:px-8 lg:px-12">
    <section class="space-y-6">
      <p class="text-sm font-medium uppercase tracking-wider text-brand-500">
        Setup en cours
      </p>
      <h1 class="text-display-xl font-bold text-ink">
        AI Discipline
      </h1>
      <p class="max-w-2xl text-lg text-ink-muted">
        Squelette Astro + Tailwind v4 initialisé. Les sections
        (Hero, Formations, Éclaireurs, Témoignages, FAQ…) seront branchées
        dans les prochaines étapes de la migration.
      </p>
      <div class="flex flex-wrap gap-3 pt-4">
        <span class="rounded-pill bg-brand-100 px-4 py-2 text-sm font-medium text-brand-700">
          Astro 6
        </span>
        <span class="rounded-pill bg-brand-100 px-4 py-2 text-sm font-medium text-brand-700">
          Tailwind v4
        </span>
        <span class="rounded-pill bg-brand-100 px-4 py-2 text-sm font-medium text-brand-700">
          TypeScript strict
        </span>
      </div>
    </section>
  </main>
</BaseLayout>
