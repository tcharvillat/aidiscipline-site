---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

import Hero from '../components/sections/Hero.astro';
import ClientLogos from '../components/sections/ClientLogos.astro';
import QualiopiBanner from '../components/sections/QualiopiBanner.astro';
import Vision from '../components/sections/Vision.astro';
import Founders from '../components/sections/Founders.astro';
import Eclaireurs from '../components/sections/Eclaireurs.astro';
import TrainingDNA from '../components/sections/TrainingDNA.astro';
import OnlineSessions from '../components/sections/OnlineSessions.astro';
import CustomDays from '../components/sections/CustomDays.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Community from '../components/sections/Community.astro';
---

<BaseLayout
  title="AI Discipline — Formations IA & Communauté pour équipes Produit & Design"
  description="Organisme de formation IA pour les équipes Produit et Design : formations en cohorte, journées sur mesure, et communauté Slack de 1 500+ praticiens."
>
  <Header />
  <main>
    <Hero />
    <ClientLogos />
    <QualiopiBanner />
    <Vision />
    <Founders />
    <Eclaireurs />
    <TrainingDNA />
    <OnlineSessions />
    <CustomDays />
    <Testimonials />
    <Community />
  </main>
  <Footer />
</BaseLayout>
